@page "/"
@attribute [AllowAnonymous]

<PageTitle>QuizSystem</PageTitle>

<section class="hero">
    <div>
        <h1>Online Quiz & Examination System</h1>
        <p>
            Production-ready platform for timed assessments, autosave attempts, role-based administration,
            and analytics dashboards.
        </p>
        <div class="hero-actions">
            <a class="btn btn-primary" href="/login">Sign in</a>
        </div>
    </div>
    <div class="hero-panel">
        <div class="metric">
            <span>Server-Authoritative Timer</span>
            <strong>Enabled</strong>
        </div>
        <div class="metric">
            <span>Autosave + Auto-submit</span>
            <strong>Enabled</strong>
        </div>
        <div class="metric">
            <span>RBAC Security</span>
            <strong>Admin / Instructor / Student</strong>
        </div>
    </div>
</section>
